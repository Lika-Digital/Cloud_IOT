# This file is a template only.
# The real .env is AUTO-GENERATED every time you run npm start / android / ios / web.
# You do NOT need to edit it manually.
#
# The script (scripts/setup-env.js) detects your machine's LAN IP automatically
# using Node's os.networkInterfaces() and writes the correct values below.
#
# Requirements:
#   - Your PC and phone must be on the same Wi-Fi network
#   - Backend must be started with: uvicorn app.main:app --host 0.0.0.0 --reload

EXPO_PUBLIC_API_URL=http://<auto-detected-LAN-IP>:8000
EXPO_PUBLIC_WS_URL=ws://<auto-detected-LAN-IP>:8000/ws
