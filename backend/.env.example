# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-string

# ── Admin seed credentials (used only on first run if no users exist) ─────────
DEFAULT_ADMIN_EMAIL=admin@your-domain.local
DEFAULT_ADMIN_PASSWORD=change-me-on-first-login

# ── SMTP ──────────────────────────────────────────────────────────────────────
# Leave SMTP_HOST empty to print OTPs to the console (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@your-domain.com

# ── MQTT broker ───────────────────────────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# ── CORS (comma-separated origins) ───────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── Company / branding (used in generated PDFs) ───────────────────────────────
COMPANY_NAME=Your Marina Name
COMPANY_ADDRESS=Street 1, 12345 City, Country
COMPANY_PHONE=+1 234 567 890
COMPANY_EMAIL=info@your-marina.com
COMPANY_PORTAL_NAME=Marina IoT Portal
