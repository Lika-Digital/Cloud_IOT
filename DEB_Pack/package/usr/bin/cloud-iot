#!/bin/bash
# cloud-iot — management CLI for the Cloud IoT marina system
set -euo pipefail

APP_DIR="/opt/cloud-iot"
BACKEND_SVC="cloud-iot-backend"
COMPOSE_SVC="cloud-iot-compose"

_require_root() {
    [[ $EUID -eq 0 ]] || { echo "This command requires sudo."; exit 1; }
}

case "${1:-help}" in

  start)
    _require_root
    echo "Starting Cloud IoT..."
    systemctl start "$COMPOSE_SVC"
    systemctl start "$BACKEND_SVC"
    echo "Done. Open http://$(hostname -I | awk '{print $1}')"
    ;;

  stop)
    _require_root
    echo "Stopping Cloud IoT..."
    systemctl stop "$BACKEND_SVC" || true
    systemctl stop "$COMPOSE_SVC" || true
    echo "Done."
    ;;

  restart)
    _require_root
    "$0" stop
    sleep 2
    "$0" start
    ;;

  status)
    echo "=== Backend service ==="
    systemctl status "$BACKEND_SVC" --no-pager -l || true
    echo ""
    echo "=== Docker compose ==="
    systemctl status "$COMPOSE_SVC" --no-pager || true
    echo ""
    echo "=== Docker containers ==="
    docker compose -f "$APP_DIR/docker-compose.yml" ps 2>/dev/null || echo "(docker-compose not running)"
    ;;

  logs)
    TARGET="${2:-backend}"
    case "$TARGET" in
      backend)  journalctl -u "$BACKEND_SVC" -f --no-pager ;;
      mqtt)     docker compose -f "$APP_DIR/docker-compose.yml" logs -f mosquitto ;;
      ml)       docker compose -f "$APP_DIR/docker-compose.yml" logs -f ml_worker ;;
      nginx)    journalctl -u nginx -f --no-pager ;;
      *)        echo "Usage: cloud-iot logs [backend|mqtt|ml|nginx]" ;;
    esac
    ;;

  download-models)
    echo "Downloading ML models (RT-DETR + DINOv2)..."
    echo "This may take several minutes on first run (~155 MB)."
    sudo -u cloud-iot /opt/cloud-iot/backend/.venv/bin/python \
        "$APP_DIR/ml_worker/setup_models.py" \
        --output "$APP_DIR/backend/models"
    echo "Models downloaded. Restart the ML worker:"
    echo "  sudo cloud-iot restart"
    ;;

  update|upgrade)
    _require_root
    echo "Pulling latest code..."
    cd "$APP_DIR"
    git pull
    echo "Rebuilding frontend..."
    sudo -u cloud-iot bash -c "cd $APP_DIR/frontend && npm ci --silent && npm run build"
    echo "Installing new Python dependencies..."
    VENV_DIR="$APP_DIR/backend/.venv"
    if [[ ! -f "$VENV_DIR/bin/pip" ]]; then
        echo "Virtual environment missing — recreating..."
        PYTHON_BIN=""
        for v in python3.13 python3.12 python3.11 python3; do
            if command -v "$v" &>/dev/null; then
                PYTHON_BIN="$v"; break
            fi
        done
        [[ -z "$PYTHON_BIN" ]] && { echo "ERROR: no python3 found"; exit 1; }
        sudo -u cloud-iot "$PYTHON_BIN" -m venv "$VENV_DIR"
        echo "Venv recreated with $PYTHON_BIN"
    fi
    sudo -u cloud-iot "$VENV_DIR/bin/pip" install --upgrade pip -q
    sudo -u cloud-iot "$VENV_DIR/bin/pip" install -q \
        -r "$APP_DIR/backend/requirements.txt" \
        email-validator
    echo "Rebuilding ML worker container..."
    docker compose -f "$APP_DIR/docker-compose.yml" build ml_worker
    "$0" restart
    echo "Update complete."
    ;;

  config)
    "${EDITOR:-nano}" "$APP_DIR/backend/.env"
    echo "Restart the backend to apply: sudo cloud-iot restart"
    ;;

  help|--help|-h|*)
    cat <<EOF
Cloud IoT — Marina Pedestal Management System

Usage: cloud-iot <command> [options]

Commands:
  start              Start all services
  stop               Stop all services
  restart            Restart all services
  status             Show service status
  logs [target]      Tail logs (backend|mqtt|ml|nginx)
  download-models    Download ML ONNX models (~155 MB)
  update|upgrade     Pull latest code and restart
  config             Edit environment configuration
  help               Show this help

First-time setup:
  sudo cloud-iot download-models   # download RT-DETR + DINOv2 models
  sudo cloud-iot start             # start everything

Web interface: http://<server-ip>
EOF
    ;;

esac
